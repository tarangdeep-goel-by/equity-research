  "_meta": {
    "description": "Curated directory of Indian-issuer Depositary Receipt programs (ADR, GDR, ADS) with custodian bank, conversion ratio, and US-side ticker. Used as the seed for `flowtracker.adr_client.AdrClient` until/unless a live scrape against a depositary directory is feasible.",
    "source_authority": "Cross-referenced from each issuer's most recent 20-F filing (SEC EDGAR), depositary bank press releases (BNY Mellon, Citi, Deutsche Bank, JPMorgan), and the issuer's own investor-relations DR fact sheets. BNY Mellon's public DR directory at adrbny.com/directory/dr-directory.html is JavaScript-rendered (XHR-loaded) and not BeautifulSoup-scrapeable; the same is true of the Citi and JPMorgan equivalents. A future live ingestion would need a headless browser or a private API key.",
    "format_notes": [
      "ratio is free-text — formats vary across depositaries (e.g. '1 ADR = 1 share', '2 GDRs = 1 share').",
      "nse_symbol is null when the issuer has no NSE-listed equivalent or has not yet been mapped by an analyst.",
      "us_ticker is null for unsponsored programs without an assigned US ticker.",
      "program_type is one of ADR, GDR, or ADS (American Depositary Share)."
    ],
    "last_updated": "2026-04-29"
  },
