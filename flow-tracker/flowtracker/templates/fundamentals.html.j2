{# ============ CHARTS ============ #}
<script>
/* ── Unified Chart: build all 6 chart configs from Screener data ── */
const rawScreenerCharts = {{ screener_charts | default({}) | tojson }};
const currentPE = {{ pe_trailing | default(0) }};
const currentPrice = {{ price }};

/* Helper: parse Screener [[date, value], ...] pairs into {labels, values} */
function parseSeries(arr) {
  if (!arr || !arr.length) return { labels: [], values: [] };
  return {
    labels: arr.map(p => p[0]),
    values: arr.map(p => typeof p[1] === 'string' ? parseFloat(p[1]) : p[1])
  };
}
/* Helper: extract volume (index 1 only, ignoring delivery object at index 2) */
function parseVolume(arr) {
  if (!arr || !arr.length) return { labels: [], values: [] };
  return {
    labels: arr.map(p => p[0]),
    values: arr.map(p => typeof p[1] === 'string' ? parseInt(p[1]) : p[1])
  };
}
/* Helper: extract numeric median value from label like "Median PE = 49.9" */
function extractMedian(dataDict, keyword) {
  for (const k of Object.keys(dataDict)) {
    if (k.indexOf(keyword || 'Median') !== -1 && k.indexOf('=') !== -1) {
      const v = parseFloat(k.split('=')[1]);
      if (!isNaN(v)) return { label: k, value: v };
    }
  }
  return null;
}

/* Helper: align sparse bar data (quarterly) onto dense label array (daily) by nearest date */
function alignSeries(denseLabels, sparseData) {
  if (!sparseData || !sparseData.labels || !sparseData.labels.length) return new Array(denseLabels.length).fill(null);
  const sparseMap = {};
  sparseData.labels.forEach((d, i) => { sparseMap[d] = sparseData.values[i]; });
  /* For each dense label, find exact match or closest prior sparse date */
  const sparseDates = sparseData.labels.slice().sort();
  return denseLabels.map(d => {
    if (sparseMap[d] !== undefined) return sparseMap[d];
    /* Find the closest sparse date <= d */
    let best = null;
    for (let i = sparseDates.length - 1; i >= 0; i--) {
      if (sparseDates[i] <= d) { best = sparseDates[i]; break; }
    }
    return best ? sparseMap[best] : null;
  });
}

/* Helper: step-fill sparse quarterly data across dense daily labels.
   Each daily label gets the value of the most recent quarterly data point,
   creating filled bars that span the full quarter period (like Screener). */
function sparseBarAlign(denseLabels, sparseData) {
  if (!sparseData || !sparseData.labels || !sparseData.labels.length) return new Array(denseLabels.length).fill(null);
  const sparseMap = {};
  sparseData.labels.forEach((d, i) => { sparseMap[d] = sparseData.values[i]; });
  const sparseDates = sparseData.labels.slice().sort();
  return denseLabels.map(d => {
    /* Find the most recent sparse date <= d */
    let best = null;
    for (let i = sparseDates.length - 1; i >= 0; i--) {
      if (sparseDates[i] <= d) { best = sparseDates[i]; break; }
    }
    return best ? sparseMap[best] : null;
  });
}

/* Common axis/grid styles */
const gridColor = 'rgba(42,45,58,0.5)';
const dimColor = '#71717a';
const textColor = '#e4e4e7';

/* Chart explain texts */
const chartExplains = {
  price: '<strong>How to read:</strong> Blue line = stock price. Yellow line = 50-day moving average (short-term trend). White line = 200-day moving average (long-term trend). When price is above 200 DMA, the stock is in an uptrend. Volume bars show trading activity.',
  pe: '<strong>How to read:</strong> Orange line shows how "expensive" or "cheap" the stock was at each point. Higher = more expensive. The green dashed line is today\'s P/E. The grey dashed line is the historical median. When price rises but P/E falls, earnings are growing faster than price.',
  margins: '<strong>How to read:</strong> Lines show margin trends (GPM, OPM, NPM as % on left axis). Bars show quarterly sales in Cr on right axis. Expanding margins + growing sales = operating leverage.',
  ev_ebitda: '<strong>How to read:</strong> EV/EBITDA line (left axis) shows enterprise valuation multiple. EBITDA bars (right axis) show absolute earnings power. Below median = potentially undervalued.',
  pb: '<strong>How to read:</strong> P/B line (left axis) shows how many times book value the market is paying. Book value bars (right axis) show net asset growth. Below median P/B = potential value.',
  mcap_sales: '<strong>How to read:</strong> Market Cap/Sales line (left axis) shows revenue multiple. Sales bars (right axis) show revenue growth. Below median = market paying less per rupee of revenue.'
};

/* Build the 6 chart configurations from raw Screener API data */
const chartConfigs = {};

/* 1. PRICE chart */
(function() {
  const sc = rawScreenerCharts.price_chart || {};
  const priceKey = Object.keys(sc).find(k => k.indexOf('Price') !== -1);
  const dma50Key = Object.keys(sc).find(k => k.indexOf('50 DMA') !== -1);
  const dma200Key = Object.keys(sc).find(k => k.indexOf('200 DMA') !== -1);
  const volKey = Object.keys(sc).find(k => k.indexOf('Volume') !== -1);
  if (!priceKey) return;
  const p = parseSeries(sc[priceKey]);
  const d50 = dma50Key ? parseSeries(sc[dma50Key]) : { labels: [], values: [] };
  const d200 = dma200Key ? parseSeries(sc[dma200Key]) : { labels: [], values: [] };
  const vol = volKey ? parseVolume(sc[volKey]) : { labels: [], values: [] };
  chartConfigs.price = {
    type: 'bar',
    data: {
      labels: p.labels,
      datasets: [
        { label: 'Volume', data: vol.values, backgroundColor: 'rgba(59,130,246,0.15)', borderWidth: 0, yAxisID: 'yRight', order: 4 },
        { label: 'Price (\u20b9)', data: p.values, type: 'line', borderColor: '#3b82f6', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y', order: 1 },
        { label: '50 DMA', data: d50.values, type: 'line', borderColor: '#eab308', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 1.5, yAxisID: 'y', order: 2 },
        { label: '200 DMA', data: d200.values, type: 'line', borderColor: 'rgba(255,255,255,0.4)', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 1.5, yAxisID: 'y', order: 3 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: textColor } },
        annotation: { annotations: {
          currentPrice: { type: 'line', yMin: currentPrice, yMax: currentPrice, borderColor: '#22c55e', borderWidth: 2, borderDash: [6, 4], label: { display: true, content: 'CMP: \u20b9' + currentPrice.toLocaleString(), position: 'start', backgroundColor: 'rgba(34,197,94,0.8)', font: { size: 11 } } }
        } }
      },
      scales: {
        x: { ticks: { color: dimColor, maxTicksLimit: 12 }, grid: { color: gridColor } },
        y: { position: 'left', ticks: { color: '#3b82f6', callback: v => '\u20b9' + v.toLocaleString() }, grid: { color: gridColor } },
        yRight: { position: 'right', ticks: { color: dimColor, callback: v => (v/1000000).toFixed(1) + 'M' }, grid: { drawOnChartArea: false }, beginAtZero: true }
      }
    }
  };
})();

/* 2. PE RATIO chart */
(function() {
  const sc = rawScreenerCharts.pe_chart || {};
  const peKey = Object.keys(sc).find(k => k === 'PE');
  const epsKey = Object.keys(sc).find(k => k.indexOf('TTM EPS') !== -1);
  if (!peKey) return;
  const pe = parseSeries(sc[peKey]);
  const eps = epsKey ? parseSeries(sc[epsKey]) : null;
  const med = extractMedian(sc, 'Median PE');
  const annotations = {};
  annotations.currentPE = { type: 'line', yMin: currentPE, yMax: currentPE, borderColor: '#22c55e', borderWidth: 2, borderDash: [6, 4], label: { display: true, content: 'Current: ' + currentPE.toFixed(1) + 'x', position: 'start', backgroundColor: 'rgba(34,197,94,0.8)', font: { size: 11 } } };
  if (med) {
    annotations.medianPE = { type: 'line', yMin: med.value, yMax: med.value, borderColor: dimColor, borderWidth: 2, borderDash: [6, 4], label: { display: true, content: 'Median: ' + med.value.toFixed(1) + 'x', position: 'end', backgroundColor: 'rgba(113,113,122,0.8)', font: { size: 11 } } };
  }
  const datasets = [
    { label: 'P/E Trailing', data: pe.values, borderColor: '#f97316', backgroundColor: 'rgba(249,115,22,0.1)', fill: true, tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y' }
  ];
  const scales = {
    x: { ticks: { color: dimColor, maxTicksLimit: 12 }, grid: { color: gridColor } },
    y: { position: 'left', ticks: { color: '#f97316' }, grid: { color: gridColor }, title: { display: true, text: 'P/E', color: '#f97316' } }
  };
  if (eps) {
    datasets.push({ label: 'TTM EPS (\u20b9)', data: eps.values, borderColor: '#3b82f6', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 1.5, yAxisID: 'yRight' });
    scales.yRight = { position: 'right', ticks: { color: '#3b82f6' }, grid: { drawOnChartArea: false }, title: { display: true, text: 'EPS (\u20b9)', color: '#3b82f6' } };
  }
  chartConfigs.pe = {
    type: 'line',
    data: { labels: pe.labels, datasets: datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: textColor } }, annotation: { annotations: annotations } },
      scales: scales
    }
  };
})();

/* 3. SALES & MARGIN chart */
(function() {
  const sc = rawScreenerCharts.margins_chart || {};
  const gpmKey = Object.keys(sc).find(k => k.indexOf('GPM') !== -1);
  const opmKey = Object.keys(sc).find(k => k.indexOf('OPM') !== -1);
  const npmKey = Object.keys(sc).find(k => k.indexOf('NPM') !== -1);
  const salesKey = Object.keys(sc).find(k => k.indexOf('Sales') !== -1 || k.indexOf('Quarter Sales') !== -1);
  if (!opmKey && !salesKey) return;
  const opm = opmKey ? parseSeries(sc[opmKey]) : null;
  const gpm = gpmKey ? parseSeries(sc[gpmKey]) : null;
  const npm = npmKey ? parseSeries(sc[npmKey]) : null;
  const sales = salesKey ? parseSeries(sc[salesKey]) : null;
  const datasets = [];
  /* Margins are all quarterly — use the longest series for labels */
  const allSeries = [gpm, opm, npm, sales].filter(Boolean);
  const longestSeries = allSeries.reduce((a, b) => a.labels.length > b.labels.length ? a : b);
  const mLabels = longestSeries.labels;
  const labels = mLabels;
  if (gpm) datasets.push({ label: 'GPM %', data: gpm.labels.length === mLabels.length ? gpm.values : sparseBarAlign(mLabels, gpm), borderColor: '#22c55e', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y', type: 'line', order: 1 });
  if (opm) datasets.push({ label: 'OPM %', data: opm.labels.length === mLabels.length ? opm.values : sparseBarAlign(mLabels, opm), borderColor: '#f97316', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y', type: 'line', order: 2 });
  if (npm) datasets.push({ label: 'NPM %', data: npm.labels.length === mLabels.length ? npm.values : sparseBarAlign(mLabels, npm), borderColor: '#a855f7', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y', type: 'line', order: 3 });
  if (sales) datasets.push({ label: 'Qtr Sales (\u20b9Cr)', data: sales.labels.length === mLabels.length ? sales.values : sparseBarAlign(mLabels, sales), backgroundColor: 'rgba(59,130,246,0.5)', yAxisID: 'yRight', order: 4 });
  const scales = {
    x: { ticks: { color: dimColor, maxTicksLimit: 12 }, grid: { color: gridColor } },
    y: { position: 'left', ticks: { color: '#f97316', callback: v => v + '%' }, grid: { color: gridColor }, title: { display: true, text: 'Margin %', color: '#f97316' } }
  };
  if (sales) scales.yRight = { position: 'right', ticks: { color: '#3b82f6' }, grid: { drawOnChartArea: false }, title: { display: true, text: '\u20b9 Cr', color: '#3b82f6' } };
  chartConfigs.margins = {
    type: 'bar',
    data: { labels: labels, datasets: datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: textColor } } },
      scales: scales
    }
  };
})();

/* 4. EV/EBITDA chart */
(function() {
  const sc = rawScreenerCharts.ev_ebitda_chart || {};
  const evKey = Object.keys(sc).find(k => k.indexOf('EV') !== -1 && k.indexOf('EBITDA') !== -1 && k.indexOf('Median') === -1);
  const ebitdaKey = Object.keys(sc).find(k => k === 'EBITDA' || (k.indexOf('EBITDA') !== -1 && k.indexOf('EV') === -1 && k.indexOf('Median') === -1));
  if (!evKey) return;
  const ev = parseSeries(sc[evKey]);
  const ebitda = ebitdaKey ? parseSeries(sc[ebitdaKey]) : null;
  const med = extractMedian(sc, 'Median');
  const annotations = {};
  if (med) {
    annotations.median = { type: 'line', yMin: med.value, yMax: med.value, borderColor: dimColor, borderWidth: 2, borderDash: [6, 4], label: { display: true, content: 'Median: ' + med.value.toFixed(1) + 'x', position: 'end', backgroundColor: 'rgba(113,113,122,0.8)', font: { size: 11 } } };
  }
  const datasets = [
    { label: 'EV/EBITDA', data: ev.values, borderColor: '#f97316', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y', type: 'line', order: 1 }
  ];
  const scales = {
    x: { ticks: { color: dimColor, maxTicksLimit: 12 }, grid: { color: gridColor } },
    y: { position: 'left', ticks: { color: '#f97316' }, grid: { color: gridColor }, title: { display: true, text: 'EV/EBITDA', color: '#f97316' } }
  };
  if (ebitda) {
    datasets.push({ label: 'EBITDA (\u20b9Cr)', data: sparseBarAlign(ev.labels, ebitda), backgroundColor: 'rgba(59,130,246,0.25)', borderWidth: 0, yAxisID: 'yRight', order: 2 });
    scales.yRight = { position: 'right', ticks: { color: '#3b82f6' }, grid: { drawOnChartArea: false }, title: { display: true, text: '\u20b9 Cr', color: '#3b82f6' } };
  }
  chartConfigs.ev_ebitda = {
    type: 'bar',
    data: { labels: ev.labels, datasets: datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: textColor } }, annotation: { annotations: annotations } },
      scales: scales
    }
  };
})();

/* 5. PRICE TO BOOK chart */
(function() {
  const sc = rawScreenerCharts.pb_chart || {};
  const pbKey = Object.keys(sc).find(k => k.indexOf('Price to BV') !== -1 || k.indexOf('P/B') !== -1 || (k.indexOf('Price') !== -1 && k.indexOf('Book') !== -1));
  const bvKey = Object.keys(sc).find(k => k.indexOf('Book Value') !== -1 && k.indexOf('Price') === -1 && k.indexOf('Median') === -1);
  if (!pbKey) return;
  const pb = parseSeries(sc[pbKey]);
  const bv = bvKey ? parseSeries(sc[bvKey]) : null;
  const med = extractMedian(sc, 'Median');
  const annotations = {};
  if (med) {
    annotations.median = { type: 'line', yMin: med.value, yMax: med.value, borderColor: dimColor, borderWidth: 2, borderDash: [6, 4], label: { display: true, content: 'Median: ' + med.value.toFixed(1) + 'x', position: 'end', backgroundColor: 'rgba(113,113,122,0.8)', font: { size: 11 } } };
  }
  const datasets = [
    { label: 'Price to Book', data: pb.values, borderColor: '#06b6d4', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y', type: 'line', order: 1 }
  ];
  const scales = {
    x: { ticks: { color: dimColor, maxTicksLimit: 12 }, grid: { color: gridColor } },
    y: { position: 'left', ticks: { color: '#06b6d4' }, grid: { color: gridColor }, title: { display: true, text: 'P/B', color: '#06b6d4' } }
  };
  if (bv) {
    datasets.push({ label: 'Book Value (\u20b9)', data: sparseBarAlign(pb.labels, bv), backgroundColor: 'rgba(34,197,94,0.25)', borderWidth: 0, yAxisID: 'yRight', order: 2 });
    scales.yRight = { position: 'right', ticks: { color: '#22c55e' }, grid: { drawOnChartArea: false }, title: { display: true, text: 'Book Value (\u20b9)', color: '#22c55e' } };
  }
  chartConfigs.pb = {
    type: 'bar',
    data: { labels: pb.labels, datasets: datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: textColor } }, annotation: { annotations: annotations } },
      scales: scales
    }
  };
})();

/* 6. MARKET CAP / SALES chart */
(function() {
  const sc = rawScreenerCharts.mcap_sales_chart || {};
  const mcKey = Object.keys(sc).find(k => k.indexOf('Market Cap') !== -1 && k.indexOf('Sales') !== -1 && k.indexOf('Median') === -1);
  const salesKey = Object.keys(sc).find(k => k === 'Sales');
  if (!mcKey) return;
  const mc = parseSeries(sc[mcKey]);
  const sales = salesKey ? parseSeries(sc[salesKey]) : null;
  const med = extractMedian(sc, 'Median');
  const annotations = {};
  if (med) {
    annotations.median = { type: 'line', yMin: med.value, yMax: med.value, borderColor: dimColor, borderWidth: 2, borderDash: [6, 4], label: { display: true, content: 'Median: ' + med.value.toFixed(1) + 'x', position: 'end', backgroundColor: 'rgba(113,113,122,0.8)', font: { size: 11 } } };
  }
  const datasets = [
    { label: 'MCap/Sales', data: mc.values, borderColor: '#eab308', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0, borderWidth: 2, yAxisID: 'y', type: 'line', order: 1 }
  ];
  const scales = {
    x: { ticks: { color: dimColor, maxTicksLimit: 12 }, grid: { color: gridColor } },
    y: { position: 'left', ticks: { color: '#eab308' }, grid: { color: gridColor }, title: { display: true, text: 'MCap/Sales', color: '#eab308' } }
  };
  if (sales) {
    datasets.push({ label: 'Sales (\u20b9Cr)', data: sparseBarAlign(mc.labels, sales), backgroundColor: 'rgba(59,130,246,0.25)', borderWidth: 0, yAxisID: 'yRight', order: 2 });
    scales.yRight = { position: 'right', ticks: { color: '#3b82f6' }, grid: { drawOnChartArea: false }, title: { display: true, text: '\u20b9 Cr', color: '#3b82f6' } };
  }
  chartConfigs.mcap_sales = {
    type: 'bar',
    data: { labels: mc.labels, datasets: datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: textColor } }, annotation: { annotations: annotations } },
      scales: scales
    }
  };
})();

/* ── Switch chart function ── */
let currentChart = null;
function switchChart(key, btn) {
  document.querySelectorAll('#metricToggles .chart-toggle').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  if (currentChart) { currentChart.destroy(); currentChart = null; }
  const explainEl = document.getElementById('chartExplain');
  if (explainEl) explainEl.innerHTML = chartExplains[key] || '';
  const cfg = chartConfigs[key];
  if (!cfg) { if (explainEl) explainEl.innerHTML = '<em>No data available for this metric.</em>'; return; }
  /* Deep-copy config to avoid Chart.js mutation issues */
  const cfgCopy = JSON.parse(JSON.stringify(cfg));
  currentChart = new Chart(document.getElementById('mainChart'), cfgCopy);
}

/* Render default chart (Price) on page load */
(function() {
  const defaultBtn = document.querySelector('#metricToggles .chart-toggle.active');
  if (defaultBtn && chartConfigs.price) {
    switchChart('price', defaultBtn);
  } else if (defaultBtn) {
    /* If no price data, try first available */
    const keys = Object.keys(chartConfigs);
    if (keys.length > 0) switchChart(keys[0], defaultBtn);
  }
})();

/* ── Shareholding toggle (Quarterly/Yearly) ── */
function toggleShTab(tab, btn) {
  document.getElementById('sh-quarterly').style.display = tab === 'quarterly' ? 'block' : 'none';
  document.getElementById('sh-yearly').style.display = tab === 'yearly' ? 'block' : 'none';
  btn.parentElement.querySelectorAll('.chart-toggle').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

/* ── DII/FII detail toggle ── */
function toggleDetail(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  const showing = el.style.display !== 'none';
  el.style.display = showing ? 'none' : 'block';
  btn.classList.toggle('active', !showing);
}

{% if qr_chart.dates %}
new Chart(document.getElementById('qrChart'), {
  type: 'bar',
  data: { labels: {{ qr_chart.dates | tojson }}, datasets: [
    { label: 'Revenue (\u20b9Cr)', data: {{ qr_chart.revenues | tojson }}, backgroundColor: 'rgba(59,130,246,0.7)', order: 2 },
    { label: 'Net Income (\u20b9Cr)', data: {{ qr_chart.net_incomes | tojson }}, backgroundColor: 'rgba(34,197,94,0.7)', order: 3 },
    { label: 'OPM %', data: {{ qr_chart.opms | tojson }}, type: 'line', borderColor: '#f97316', backgroundColor: 'transparent', tension: 0.3, pointRadius: 3, borderWidth: 2, yAxisID: 'y1', order: 1 }
  ] },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: '#e4e4e7' } } },
    scales: {
      x: { ticks: { color: '#71717a' }, grid: { color: 'rgba(42,45,58,0.5)' } },
      y: { position: 'left', ticks: { color: '#71717a' }, grid: { color: 'rgba(42,45,58,0.5)' }, title: { display: true, text: '\u20b9 Cr', color: '#71717a' } },
      y1: { position: 'right', min: 0, max: 50, ticks: { color: '#f97316' }, grid: { drawOnChartArea: false }, title: { display: true, text: 'OPM %', color: '#f97316' } }
    }
  }
});
{% endif %}

{# Shareholding stacked bar chart #}
{% if shareholding_history and shareholding_history|length >= 2 %}
{% set sh_reversed = shareholding_history | reverse | list %}
new Chart(document.getElementById('shChart'), {
  type: 'bar',
  data: {
    labels: {{ sh_reversed | map(attribute='quarter') | list | tojson }},
    datasets: [
      { label: 'Promoter', data: {{ sh_reversed | map(attribute='promoter', default=0) | list | tojson }}, backgroundColor: 'rgba(59,130,246,0.8)' },
      { label: 'FII', data: {{ sh_reversed | map(attribute='fii', default=0) | list | tojson }}, backgroundColor: 'rgba(249,115,22,0.8)' },
      { label: 'MF', data: {{ sh_reversed | map(attribute='mf', default=0) | list | tojson }}, backgroundColor: 'rgba(34,197,94,0.8)' },
      { label: 'DII', data: {{ sh_reversed | map(attribute='dii', default=0) | list | tojson }}, backgroundColor: 'rgba(168,85,247,0.8)' },
      { label: 'Public', data: {{ sh_reversed | map(attribute='public', default=0) | list | tojson }}, backgroundColor: 'rgba(113,113,122,0.7)' }
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: '#e4e4e7' } } },
    scales: {
      x: { stacked: true, ticks: { color: '#71717a' }, grid: { color: 'rgba(42,45,58,0.5)' } },
      y: { stacked: true, max: 100, ticks: { color: '#71717a', callback: v => v + '%' }, grid: { color: 'rgba(42,45,58,0.5)' } }
    }
  }
});
{% endif %}

{# ROE history bar chart #}
{% if roe_history and roe_history|selectattr('roe')|list %}
new Chart(document.getElementById('roeChart'), {
  type: 'bar',
  data: {
    labels: {{ roe_history | map(attribute='year') | list | tojson }},
    datasets: [{
      label: 'ROE %',
      data: {{ roe_history | map(attribute='roe') | list | tojson }},
      backgroundColor: {{ roe_history | map(attribute='roe') | list | map('default', 0) | list | tojson }}.map(v => v && v >= 15 ? 'rgba(34,197,94,0.7)' : 'rgba(239,68,68,0.5)'),
      borderRadius: 4
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      annotation: { annotations: {
        goodROE: { type: 'line', yMin: 15, yMax: 15, borderColor: '#71717a', borderWidth: 1, borderDash: [4, 4], label: { display: true, content: '15% (good)', position: 'start', backgroundColor: 'rgba(113,113,122,0.8)', font: { size: 10 } } }
      } }
    },
    scales: {
      x: { ticks: { color: '#71717a' }, grid: { color: 'rgba(42,45,58,0.5)' } },
      y: { ticks: { color: '#71717a', callback: v => v + '%' }, grid: { color: 'rgba(42,45,58,0.5)' } }
    }
  }
});
{% endif %}
</script>
</body>
</html>
