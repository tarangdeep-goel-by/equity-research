# serializer version: 1
# name: test_help_outputs_match_snapshot
  dict({
    '--help': "Usage: flowtrack [OPTIONS] COMMAND [ARGS]... FII/DII institutional flow tracker for Indian markets Options --install-completion Install completion for the current shell. --show-completion Show completion for the current shell, to copy it or customize the installation. --help Show this message and exit. Commands fetch Fetch today's FII/DII data from NSE and store in local database. summary Show most recent day's FII/DII flows. flows Show historical FII/DII flows for the given period. streak Show current FII/DII buying/selling streaks. backfill Import historical FII/DII data from a CSV or XLSX file. fund Fundamentals: valuation, earnings, peer comparison mf AMFI mutual fund flow data — monthly scheme-category-level flows and AUM holding NSE shareholding patterns — quarterly promoter/FII/DII/MF/public ownership scan Nifty 250 shareholding scanner — batch fetch and rank ownership deviations gold Gold and silver prices — track commodity rotation alongside equity flows macro Macro indicators — VIX, USD/INR, Brent crude, 10Y G-sec yield bhavcopy Daily OHLCV + delivery data — track conviction via delivery % fno F&O (futures & options) ingestion — bhavcopy, participant OI, option chain deals Bulk/block deals — track large institutional transactions insider Insider/SAST transactions — track promoter and insider trading activity estimates Consensus estimates — analyst targets, recommendations, earnings surprises fmp FMP data — DCF valuation, technicals, key metrics, growth, analyst grades, price targets sector Sector aggregation — ownership shifts and rotation by industry mfport MF scheme holdings — track what mutual funds are buying and selling screen Composite stock screener — multi-factor scoring across all data layers filings Corporate filings — investor presentations, concalls, annual reports from BSE/NSE portfolio Track portfolio holdings — P&L, sector concentration, summary alert Condition-based alerts — price, PE, RSI, ownership, pledge thresholds research Generate deep-dive research reports catalyst Upcoming stock catalyst events share_count Screener-vs-yfinance share-count divergence sanity check adr ADR/GDR program directory (Indian issuers)",
    'alert --help': 'Usage: flowtrack alert [OPTIONS] COMMAND [ARGS]... Condition-based alerts — price, PE, RSI, ownership, pledge thresholds Options --help Show this message and exit. Commands add Create a new alert. list Show all active alerts. check Run all active alerts against current data. remove Deactivate an alert. history Show alert trigger history.',
    'alert add --help': 'Usage: flowtrack alert add [OPTIONS] SYMBOL CONDITION_TYPE THRESHOLD Create a new alert. Arguments * symbol TEXT Stock symbol [required] * condition_type TEXT Condition: price_above, price_below, pe_above, pe_below, fii_pct_below, mf_pct_above, rsi_below, rsi_above, pledge_above, dcf_upside_above [required] * threshold FLOAT Threshold value [required] Options --notes -n TEXT Notes --help Show this message and exit.',
    'alert check --help': 'Usage: flowtrack alert check [OPTIONS] Run all active alerts against current data. Options --help Show this message and exit.',
    'alert history --help': 'Usage: flowtrack alert history [OPTIONS] Show alert trigger history. Options --limit -l INTEGER Number of records [default: 20] --help Show this message and exit.',
    'alert list --help': 'Usage: flowtrack alert list [OPTIONS] Show all active alerts. Options --help Show this message and exit.',
    'alert remove --help': 'Usage: flowtrack alert remove [OPTIONS] ALERT_ID Deactivate an alert. Arguments * alert_id INTEGER Alert ID to deactivate [required] Options --help Show this message and exit.',
    'backfill --help': 'Usage: flowtrack backfill [OPTIONS] FILE Import historical FII/DII data from a CSV or XLSX file. Arguments * file PATH Path to CSV or XLSX file with historical FII/DII data [required] Options --help Show this message and exit.',
    'bhavcopy --help': 'Usage: flowtrack bhavcopy [OPTIONS] COMMAND [ARGS]... Daily OHLCV + delivery data — track conviction via delivery % Options --help Show this message and exit. Commands fetch Fetch bhavcopy for a single trading day. backfill Bulk fetch historical bhavcopy data. top-delivery Show stocks with highest delivery % (conviction signal). delivery Show delivery % trend for a stock.',
    'bhavcopy backfill --help': 'Usage: flowtrack bhavcopy backfill [OPTIONS] Bulk fetch historical bhavcopy data. Options --from TEXT Start date YYYY-MM-DD [default: 2024-01-01] --to TEXT End date YYYY-MM-DD (default: today) --help Show this message and exit.',
    'bhavcopy delivery --help': 'Usage: flowtrack bhavcopy delivery [OPTIONS] SYMBOL Show delivery % trend for a stock. Arguments * symbol TEXT Stock symbol [required] Options --days -d INTEGER Number of days [default: 30] --help Show this message and exit.',
    'bhavcopy fetch --help': 'Usage: flowtrack bhavcopy fetch [OPTIONS] Fetch bhavcopy for a single trading day. Options --date TEXT Date as YYYY-MM-DD (default: today) --help Show this message and exit.',
    'bhavcopy top-delivery --help': 'Usage: flowtrack bhavcopy top-delivery [OPTIONS] Show stocks with highest delivery % (conviction signal). Options --date TEXT Date as YYYY-MM-DD --limit -n INTEGER Number of stocks to show [default: 20] --help Show this message and exit.',
    'deals --help': "Usage: flowtrack deals [OPTIONS] COMMAND [ARGS]... Bulk/block deals — track large institutional transactions Options --help Show this message and exit. Commands fetch Fetch today's bulk/block deals from NSE. summary Show latest day's deals grouped by type. stock Show deal history for a specific stock. top Show biggest deals by value.",
    'deals fetch --help': "Usage: flowtrack deals fetch [OPTIONS] Fetch today's bulk/block deals from NSE. Options --help Show this message and exit.",
    'deals stock --help': 'Usage: flowtrack deals stock [OPTIONS] SYMBOL Show deal history for a specific stock. Arguments * symbol TEXT Stock symbol [required] Options --help Show this message and exit.',
    'deals summary --help': "Usage: flowtrack deals summary [OPTIONS] Show latest day's deals grouped by type. Options --help Show this message and exit.",
    'deals top --help': 'Usage: flowtrack deals top [OPTIONS] Show biggest deals by value. Options --days -d INTEGER Number of days to look back [default: 30] --limit -n INTEGER Number of deals to show [default: 20] --help Show this message and exit.',
    'estimates --help': 'Usage: flowtrack estimates [OPTIONS] COMMAND [ARGS]... Consensus estimates — analyst targets, recommendations, earnings surprises Options --help Show this message and exit. Commands fetch Fetch estimates for all Nifty 500 stocks. stock Show full estimates for a stock. upside Show stocks ranked by upside to analyst target. surprises Show recent earnings beats/misses.',
    'estimates fetch --help': 'Usage: flowtrack estimates fetch [OPTIONS] Fetch estimates for all Nifty 500 stocks. Options --help Show this message and exit.',
    'estimates stock --help': 'Usage: flowtrack estimates stock [OPTIONS] SYMBOL Show full estimates for a stock. Arguments * symbol TEXT Stock symbol [required] Options --help Show this message and exit.',
    'estimates surprises --help': 'Usage: flowtrack estimates surprises [OPTIONS] Show recent earnings beats/misses. Options --days -d INTEGER Days to look back [default: 90] --help Show this message and exit.',
    'estimates upside --help': 'Usage: flowtrack estimates upside [OPTIONS] Show stocks ranked by upside to analyst target. Options --help Show this message and exit.',
    'fetch --help': "Usage: flowtrack fetch [OPTIONS] Fetch today's FII/DII data from NSE and store in local database. Options --help Show this message and exit.",
    'filings --help': "Usage: flowtrack filings [OPTIONS] COMMAND [ARGS]... Corporate filings — investor presentations, concalls, annual reports from BSE/NSE Options --help Show this message and exit. Commands fetch Fetch corporate filings from BSE and optionally download PDFs. download Download all PDFs for a stock's filings. list List stored filings for a stock. annual-reports Fetch and optionally download annual reports from NSE. open-filing Open a downloaded filing PDF. extract Extract structured insights from concall PDFs using AI. download-ar Download annual report PDFs for the last N FYs to the vault. extract-ar Extract structured insights from annual report PDFs via Docling + AI. extract-deck Extract structured insights from investor-deck PDFs via Docling + AI. extract-press-release Extract BFSI quarterly press-release metrics (NIM, NPA, PCR, CRAR, CET-1, LCR, CASA).",
    'filings annual-reports --help': 'Usage: flowtrack filings annual-reports [OPTIONS] SYMBOL Fetch and optionally download annual reports from NSE. Arguments * symbol TEXT Stock symbol [required] Options --download Download the PDFs --help Show this message and exit.',
    'filings download --help': "Usage: flowtrack filings download [OPTIONS] SYMBOL Download all PDFs for a stock's filings. Arguments * symbol TEXT Stock symbol [required] Options --help Show this message and exit.",
    'filings extract --help': 'Usage: flowtrack filings extract [OPTIONS] Extract structured insights from concall PDFs using AI. Options * --symbol -s TEXT Stock symbol [required] --quarters -q INTEGER Number of quarters to extract [default: 4] --model -m TEXT Claude model to use --help Show this message and exit.',
    'filings extract-press-release --help': "Usage: flowtrack filings extract-press-release [OPTIONS] Extract BFSI quarterly press-release metrics (NIM, NPA, PCR, CRAR, CET-1, LCR, CASA). Reads ``corporate_filings`` rows for the symbol's last N quarters, downloads the press release / financial results PDF if missing, runs the text through Claude (no OCR — text PDFs only), and persists structured metrics to ``~/vault/stocks/{SYMBOL}/fundamentals/press_release_extraction_v1.json``. Industry gate: only fires for banks/NBFCs. Skipped for non-BFSI symbols. Options * --symbol -s TEXT Stock symbol (must be BFSI) [required] --quarters -q INTEGER Number of recent quarters to extract [default: 2] --model -m TEXT Claude model to use --force Re-extract all quarters, ignoring cached JSON --help Show this message and exit.",
    'filings fetch --help': 'Usage: flowtrack filings fetch [OPTIONS] SYMBOL Fetch corporate filings from BSE and optionally download PDFs. Arguments * symbol TEXT Stock symbol [required] Options --years -y INTEGER Years of history [default: 3] --download Also download PDFs --help Show this message and exit.',
    'filings list --help': 'Usage: flowtrack filings list [OPTIONS] SYMBOL List stored filings for a stock. Arguments * symbol TEXT Stock symbol [required] Options --category -c TEXT Filter by category --limit -n INTEGER Number to show [default: 30] --help Show this message and exit.',
    'filings open-filing --help': "Usage: flowtrack filings open-filing [OPTIONS] SYMBOL [INDEX] Open a downloaded filing PDF. Arguments * symbol TEXT Stock symbol [required] index [INDEX] Filing index (from 'filings list') [default: 1] Options --help Show this message and exit.",
    'flows --help': "Usage: flowtrack flows [OPTIONS] Show historical FII/DII flows for the given period. Options --period -p TEXT Period like '7d' or '30d' [default: 7d] --help Show this message and exit.",
    'fmp --help': 'Usage: flowtrack fmp [OPTIONS] COMMAND [ARGS]... FMP data — DCF valuation, technicals, key metrics, growth, analyst grades, price targets Options --help Show this message and exit. Commands fetch Fetch all FMP data for a stock and store in DB. dcf Show DCF intrinsic value for a stock. technicals Show technical indicators (RSI, SMA, MACD, ADX). metrics Show key financial metrics history. growth Show financial growth rates. grades Show analyst grade changes (upgrades/downgrades). targets Show analyst price targets.',
    'fmp dcf --help': 'Usage: flowtrack fmp dcf [OPTIONS] Show DCF intrinsic value for a stock. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fmp fetch --help': 'Usage: flowtrack fmp fetch [OPTIONS] Fetch all FMP data for a stock and store in DB. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fmp grades --help': 'Usage: flowtrack fmp grades [OPTIONS] Show analyst grade changes (upgrades/downgrades). Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fmp growth --help': 'Usage: flowtrack fmp growth [OPTIONS] Show financial growth rates. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fmp metrics --help': 'Usage: flowtrack fmp metrics [OPTIONS] Show key financial metrics history. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fmp targets --help': 'Usage: flowtrack fmp targets [OPTIONS] Show analyst price targets. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fmp technicals --help': 'Usage: flowtrack fmp technicals [OPTIONS] Show technical indicators (RSI, SMA, MACD, ADX). Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fund --help': 'Usage: flowtrack fund [OPTIONS] COMMAND [ARGS]... Fundamentals: valuation, earnings, peer comparison Options --help Show this message and exit. Commands fetch Fetch valuation snapshots from yfinance. show Live fetch — display current fundamentals snapshot. history Display stored quarterly earnings trajectory. peers Live fetch peer comparison. valuation Display valuation bands from stored snapshots. backfill Backfill 10yr historical data from Screener.in + yfinance. charts Fetch and display Screener.in chart data. peer Fetch and display peer comparison from Screener.in. schedules Fetch and display schedule breakdowns from Screener.in. irdai-backfill Populate ``net_premium_earned`` from the curated IRDAI dataset.',
    'fund backfill --help': 'Usage: flowtrack fund backfill [OPTIONS] Backfill 10yr historical data from Screener.in + yfinance. Downloads quarterly results (10Q) and annual EPS (10yr) from Screener.in, then computes historical weekly P/E from annual EPS + yfinance prices. Options --symbol -s TEXT Backfill single stock --quarters-only Only fetch Screener.in quarterly data --valuation-only Only compute historical P/E --help Show this message and exit.',
    'fund charts --help': 'Usage: flowtrack fund charts [OPTIONS] Fetch and display Screener.in chart data. Options * --symbol -s TEXT Stock symbol [required] --type -t TEXT Chart type: price, pe, sales_margin, ev_ebitda, pbv, mcap_sales [default: pe] --help Show this message and exit.',
    'fund fetch --help': "Usage: flowtrack fund fetch [OPTIONS] Fetch valuation snapshots from yfinance. Fetches daily valuation metrics (P/E, P/B, margins, beta, etc.) for all Nifty 500 stocks. Quarterly results come from Screener.in via 'fund backfill'. Options --symbol -s TEXT Fetch for specific symbol --valuation-only Only fetch valuation snapshot --help Show this message and exit.",
    'fund history --help': 'Usage: flowtrack fund history [OPTIONS] SYMBOL Display stored quarterly earnings trajectory. Arguments * symbol TEXT Stock symbol [required] Options --quarters -q INTEGER Number of quarters to show [default: 8] --help Show this message and exit.',
    'fund irdai-backfill --help': 'Usage: flowtrack fund irdai-backfill [OPTIONS] Populate ``net_premium_earned`` from the curated IRDAI dataset. Reads ``flowtracker/data/irdai_net_premium.json`` (Form L-1-A-RA Premium earned (Net) for the four publicly-listed Indian life insurers) and writes the values onto matching ``annual_financials`` and ``quarterly_results`` rows. Existing rows for other columns are untouched — this is a column-only enrichment. Run ``flowtrack fund backfill`` first to seed the Screener-side rows. Re-run after each new IRDAI quarterly disclosure to top up. Options --symbol -s TEXT Backfill a single insurer; default is all covered insurers --help Show this message and exit.',
    'fund peer --help': 'Usage: flowtrack fund peer [OPTIONS] Fetch and display peer comparison from Screener.in. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'fund peers --help': 'Usage: flowtrack fund peers [OPTIONS] SYMBOL Live fetch peer comparison. Arguments * symbol TEXT Stock symbol [required] Options --with TEXT Comma-separated peer symbols (e.g. TCS,INFY,WIPRO) --help Show this message and exit.',
    'fund schedules --help': 'Usage: flowtrack fund schedules [OPTIONS] Fetch and display schedule breakdowns from Screener.in. Options * --symbol -s TEXT Stock symbol [required] --section TEXT Section: quarters, profit-loss, balance-sheet, cash-flow [default: profit-loss] --parent TEXT Parent line item (e.g. Sales, Expenses, Borrowings) [default: Sales] --help Show this message and exit.',
    'fund show --help': 'Usage: flowtrack fund show [OPTIONS] SYMBOL Live fetch — display current fundamentals snapshot. Arguments * symbol TEXT Stock symbol [required] Options --help Show this message and exit.',
    'fund valuation --help': 'Usage: flowtrack fund valuation [OPTIONS] SYMBOL Display valuation bands from stored snapshots. Arguments * symbol TEXT Stock symbol [required] Options --period TEXT Period: 1y, 2y, 3y [default: 3y] --help Show this message and exit.',
    'gold --help': 'Usage: flowtrack gold [OPTIONS] COMMAND [ARGS]... Gold and silver prices — track commodity rotation alongside equity flows Options --help Show this message and exit. Commands fetch Fetch gold/silver prices and ETF NAVs. metals Fetch industrial metals prices (aluminium / copper) from yfinance. prices Show recent gold and silver prices. etfs Show gold/silver ETF NAV trends. correlation Show FII equity flows vs gold price changes.',
    'gold correlation --help': 'Usage: flowtrack gold correlation [OPTIONS] Show FII equity flows vs gold price changes. Options --days -d INTEGER Number of days to analyze [default: 30] --help Show this message and exit.',
    'gold etfs --help': 'Usage: flowtrack gold etfs [OPTIONS] Show gold/silver ETF NAV trends. Options --days -d INTEGER Number of days to show [default: 30] --help Show this message and exit.',
    'gold fetch --help': 'Usage: flowtrack gold fetch [OPTIONS] Fetch gold/silver prices and ETF NAVs. Options --backfill Fetch full history from 2010 --days -d INTEGER Days of recent data [default: 30] --help Show this message and exit.',
    'gold prices --help': 'Usage: flowtrack gold prices [OPTIONS] Show recent gold and silver prices. Options --days -d INTEGER Number of days to show [default: 14] --help Show this message and exit.',
    'holding --help': 'Usage: flowtrack holding [OPTIONS] COMMAND [ARGS]... NSE shareholding patterns — quarterly promoter/FII/DII/MF/public ownership Options --help Show this message and exit. Commands add Add stocks to watchlist. remove Remove a stock from watchlist. list Show all stocks in watchlist. fetch Fetch shareholding data from NSE XBRL filings. show Show shareholding history for a stock. changes Show biggest shareholding changes across watchlist stocks. shareholders Fetch individual shareholder details from Screener.in.',
    'holding add --help': 'Usage: flowtrack holding add [OPTIONS] SYMBOLS... Add stocks to watchlist. Arguments * symbols SYMBOLS... Stock symbols to add (e.g. RELIANCE TCS INFY) [required] Options --help Show this message and exit.',
    'holding changes --help': 'Usage: flowtrack holding changes [OPTIONS] Show biggest shareholding changes across watchlist stocks. Options --category -c TEXT Filter by category: FII, DII, MF, Promoter, Public --limit -n INTEGER Number of results [default: 10] --help Show this message and exit.',
    'holding fetch --help': 'Usage: flowtrack holding fetch [OPTIONS] Fetch shareholding data from NSE XBRL filings. Options --symbol -s TEXT Fetch for specific symbol (default: all in watchlist) --quarters -q INTEGER Number of quarters to fetch [default: 4] --help Show this message and exit.',
    'holding list --help': 'Usage: flowtrack holding list [OPTIONS] Show all stocks in watchlist. Options --help Show this message and exit.',
    'holding remove --help': 'Usage: flowtrack holding remove [OPTIONS] SYMBOL Remove a stock from watchlist. Arguments * symbol TEXT Stock symbol to remove [required] Options --help Show this message and exit.',
    'holding shareholders --help': 'Usage: flowtrack holding shareholders [OPTIONS] Fetch individual shareholder details from Screener.in. Options * --symbol -s TEXT Stock symbol [required] --classification -c TEXT Filter: promoters, foreign_institutions, domestic_institutions, public --help Show this message and exit.',
    'holding show --help': 'Usage: flowtrack holding show [OPTIONS] SYMBOL Show shareholding history for a stock. Arguments * symbol TEXT Stock symbol [required] Options --quarters -q INTEGER Number of quarters to show [default: 8] --help Show this message and exit.',
    'insider --help': 'Usage: flowtrack insider [OPTIONS] COMMAND [ARGS]... Insider/SAST transactions — track promoter and insider trading activity Options --help Show this message and exit. Commands fetch Fetch recent insider transactions from NSE. stock Show insider activity for a specific stock. promoter-buys Show promoter buying activity (highest conviction signal). backfill Backfill insider transactions for a full year.',
    'insider backfill --help': 'Usage: flowtrack insider backfill [OPTIONS] YEAR Backfill insider transactions for a full year. Arguments * year INTEGER Year to backfill (e.g. 2024) [required] Options --help Show this message and exit.',
    'insider fetch --help': 'Usage: flowtrack insider fetch [OPTIONS] Fetch recent insider transactions from NSE. Options --days -d INTEGER Days to look back [default: 7] --help Show this message and exit.',
    'insider promoter-buys --help': 'Usage: flowtrack insider promoter-buys [OPTIONS] Show promoter buying activity (highest conviction signal). Options --days -d INTEGER Days to look back [default: 30] --help Show this message and exit.',
    'insider stock --help': 'Usage: flowtrack insider stock [OPTIONS] SYMBOL Show insider activity for a specific stock. Arguments * symbol TEXT Stock symbol [required] Options --days -d INTEGER Days to look back [default: 365] --help Show this message and exit.',
    'macro --help': 'Usage: flowtrack macro [OPTIONS] COMMAND [ARGS]... Macro indicators — VIX, USD/INR, Brent crude, 10Y G-sec yield Options --help Show this message and exit. Commands fetch Fetch macro indicator snapshots. fetch-index Fetch Nifty 500 + Nifty 50 index daily prices. summary Show latest macro indicators with changes. trend Show macro indicator trend. wss-fetch Fetch RBI WSS system credit/deposit aggregates (weekly). wss-summary Show the latest RBI WSS system-credit snapshot.',
    'macro fetch --help': 'Usage: flowtrack macro fetch [OPTIONS] Fetch macro indicator snapshots. Options --backfill Fetch full history from 2008 --days -d INTEGER Days of recent data [default: 5] --help Show this message and exit.',
    'macro summary --help': 'Usage: flowtrack macro summary [OPTIONS] Show latest macro indicators with changes. Options --help Show this message and exit.',
    'macro trend --help': 'Usage: flowtrack macro trend [OPTIONS] Show macro indicator trend. Options --days -d INTEGER Number of days to show [default: 30] --help Show this message and exit.',
    'macro wss-fetch --help': "Usage: flowtrack macro wss-fetch [OPTIONS] Fetch RBI WSS system credit/deposit aggregates (weekly). Idempotent — re-running for a release that's already in the DB overwrites with whatever the parser extracts this run. Options --date TEXT Override release date (RBI format M/DD/YYYY). Default = latest release. --help Show this message and exit.",
    'macro wss-summary --help': 'Usage: flowtrack macro wss-summary [OPTIONS] Show the latest RBI WSS system-credit snapshot. Options --help Show this message and exit.',
    'mf --help': "Usage: flowtrack mf [OPTIONS] COMMAND [ARGS]... AMFI mutual fund flow data — monthly scheme-category-level flows and AUM Options --help Show this message and exit. Commands fetch Fetch a specific month's AMFI report (defaults to previous month). summary Show latest month's MF AUM summary by category. flows Show historical MF flows by category. aum Show MF AUM trend over time (equity % of total, monthly). backfill Bulk import AMFI reports for a date range. daily SEBI daily MF equity/debt purchase and sale data",
    'mf aum --help': 'Usage: flowtrack mf aum [OPTIONS] Show MF AUM trend over time (equity % of total, monthly). Options --help Show this message and exit.',
    'mf backfill --help': 'Usage: flowtrack mf backfill [OPTIONS] Bulk import AMFI reports for a date range. Options --from TEXT Start month (YYYY-MM) [default: 2019-04] --to TEXT End month (YYYY-MM) --help Show this message and exit.',
    'mf daily --help': "Usage: flowtrack mf daily [OPTIONS] COMMAND [ARGS]... SEBI daily MF equity/debt purchase and sale data Options --help Show this message and exit. Commands fetch Fetch current month's daily MF flows from SEBI. summary Show latest day's MF daily flows (equity + debt). trend Show daily MF equity/debt net investment trend.",
    'mf daily fetch --help': "Usage: flowtrack mf daily fetch [OPTIONS] Fetch current month's daily MF flows from SEBI. Options --help Show this message and exit.",
    'mf daily summary --help': "Usage: flowtrack mf daily summary [OPTIONS] Show latest day's MF daily flows (equity + debt). Options --help Show this message and exit.",
    'mf daily trend --help': 'Usage: flowtrack mf daily trend [OPTIONS] Show daily MF equity/debt net investment trend. Options --days -d INTEGER Number of days [default: 30] --help Show this message and exit.',
    'mf fetch --help': "Usage: flowtrack mf fetch [OPTIONS] Fetch a specific month's AMFI report (defaults to previous month). Options --month -m INTEGER Month (1-12) [default: 0] --year -y INTEGER Year (e.g. 2026) [default: 0] --help Show this message and exit.",
    'mf flows --help': "Usage: flowtrack mf flows [OPTIONS] Show historical MF flows by category. Options --period -p TEXT Period like '12m' or '6m' [default: 12m] --category -c TEXT Filter by category: Equity, Debt, Hybrid --help Show this message and exit.",
    'mf summary --help': "Usage: flowtrack mf summary [OPTIONS] Show latest month's MF AUM summary by category. Options --help Show this message and exit.",
    'mfport --help': 'Usage: flowtrack mfport [OPTIONS] COMMAND [ARGS]... MF scheme holdings — track what mutual funds are buying and selling Options --help Show this message and exit. Commands fetch Fetch MF portfolio holdings from AMC disclosures. stock Show which MF schemes hold a stock. top-buys Show biggest new positions and increases by MFs. top-exits Show biggest exits and decreases by MFs. summary Show AMC-level portfolio summary.',
    'mfport fetch --help': 'Usage: flowtrack mfport fetch [OPTIONS] Fetch MF portfolio holdings from AMC disclosures. Options --month TEXT Month as YYYY-MM (default: previous month) --amc TEXT Single AMC code: SBI, ICICI, PPFAS, QUANT, UTI --help Show this message and exit.',
    'mfport stock --help': 'Usage: flowtrack mfport stock [OPTIONS] SYMBOL Show which MF schemes hold a stock. Arguments * symbol TEXT Stock name or ISIN to search [required] Options --help Show this message and exit.',
    'mfport summary --help': 'Usage: flowtrack mfport summary [OPTIONS] Show AMC-level portfolio summary. Options --month TEXT Month as YYYY-MM --help Show this message and exit.',
    'mfport top-buys --help': 'Usage: flowtrack mfport top-buys [OPTIONS] Show biggest new positions and increases by MFs. Options --month TEXT Month as YYYY-MM --limit -n INTEGER Number of changes to show [default: 30] --help Show this message and exit.',
    'mfport top-exits --help': 'Usage: flowtrack mfport top-exits [OPTIONS] Show biggest exits and decreases by MFs. Options --month TEXT Month as YYYY-MM --limit -n INTEGER Number of changes to show [default: 30] --help Show this message and exit.',
    'portfolio --help': 'Usage: flowtrack portfolio [OPTIONS] COMMAND [ARGS]... Track portfolio holdings — P&L, sector concentration, summary Options --help Show this message and exit. Commands add Add or update a portfolio holding. remove Remove a holding from the portfolio. view Show all holdings with current price and P&L. concentration Show sector breakdown of portfolio. summary Show portfolio-level summary: total invested, P&L, top gainer/loser.',
    'portfolio add --help': 'Usage: flowtrack portfolio add [OPTIONS] SYMBOL Add or update a portfolio holding. Arguments * symbol TEXT Stock symbol [required] Options * --qty -q INTEGER Number of shares [required] * --cost -c FLOAT Average cost per share [required] --date -d TEXT Buy date (YYYY-MM-DD) --notes -n TEXT Notes --help Show this message and exit.',
    'portfolio concentration --help': 'Usage: flowtrack portfolio concentration [OPTIONS] Show sector breakdown of portfolio. Options --help Show this message and exit.',
    'portfolio remove --help': 'Usage: flowtrack portfolio remove [OPTIONS] SYMBOL Remove a holding from the portfolio. Arguments * symbol TEXT Stock symbol to remove [required] Options --help Show this message and exit.',
    'portfolio summary --help': 'Usage: flowtrack portfolio summary [OPTIONS] Show portfolio-level summary: total invested, P&L, top gainer/loser. Options --help Show this message and exit.',
    'portfolio view --help': 'Usage: flowtrack portfolio view [OPTIONS] Show all holdings with current price and P&L. Options --help Show this message and exit.',
    'research --help': "Usage: flowtrack research [OPTIONS] COMMAND [ARGS]... Generate deep-dive research reports Options --help Show this message and exit. Commands fundamentals Generate a fundamentals HTML report for a stock. business Generate a business profile — what the company does, how it makes money. thesis Generate comprehensive multi-agent equity research thesis. explain Run the explainer agent on an existing report to add beginner-friendly annotations. data Query any research data tool directly. Prints JSON output. thesis-check Quick condition check for a tracked stock's thesis. thesis-status Summary of all tracked stocks with condition status. compare Compare 2-5 stocks side-by-side with AI-generated comparative analysis. run Run specialist research agents on a stock. verify Verify an existing specialist report (checks data accuracy). autoeval Run autoeval — Gemini grading loop for specialist agents. autoeval-macro Run macro autoeval — Gemini grading loop for the macro regime agent. analog-backtest Run the Historical Analog empirical backtest — calibrates directional adjustments against realized 12m forward returns.",
    'research analog-backtest --help': "Usage: flowtrack research analog-backtest [OPTIONS] Run the Historical Analog empirical backtest — calibrates directional adjustments against realized 12m forward returns. Stratified samples ``--n`` ``(symbol, as_of_date)`` points where 12m forward returns are observable, runs the historical_analog agent backdated via FLOWTRACK_AS_OF, then scores the briefing's ``directional_adjustments`` against the realized return's quartile within the retrieved cohort. Calibration thresholds: * Thicker call passes if hit rate >= 0.35 * Thinner call passes if hit rate >= 0.85 (i.e. realized rarely lands in the claimed-thin tail) Archives metadata + per-sample rows + calibration summary to ``autoeval/eval_history/analog_backtest_<ts>.json``. Recommended cadence: monthly (~3hr wall-clock, ~$8 cost at N=20). Examples: flowtrack research analog-backtest --n 20 --seed 42 --note baseline flowtrack research analog-backtest --skip-run --note regrade-only Options --n INTEGER Sample size (default 20) [default: 20] --seed INTEGER Random seed for stratified sampler (default 42) [default: 42] --skip-run Skip agent runs; re-score using existing briefings under ~/.local/share/flowtracker/backtest/ --cutoff-days INTEGER Min age (days) for a sample's as_of (default 450 = 12mo + buffer) [default: 450] --note TEXT Free-form note threaded into the eval_history archive (e.g. 'baseline-post-scaffolds') --help Show this message and exit.",
    'research autoeval-macro --help': "Usage: flowtrack research autoeval-macro [OPTIONS] Run macro autoeval — Gemini grading loop for the macro regime agent. Flat date matrix (no sector × stock). Each as-of date runs the macro agent backdated via FLOWTRACK_AS_OF, then grades the report with the macro rubric (anchor exhaustion, trajectory check, FACT/VIEW, India transmission, stale policy). Results land in results_macro.tsv next to results.tsv. Examples: flowtrack research autoeval-macro # all matrix dates flowtrack research autoeval-macro --dates 2025-11-01 # one date flowtrack research autoeval-macro --skip-run --note baseline # grade only Options --dates TEXT Comma-separated as-of dates (override matrix; default = all dates in eval_matrix_macro.yaml) --skip-run Grade existing macro reports without re-running the agent --note TEXT Free-form note threaded into the eval_history archive (e.g. 'baseline', 'post-prompt-fix-3') --help Show this message and exit.",
    'research business --help': 'Usage: flowtrack research business [OPTIONS] Generate a business profile — what the company does, how it makes money. Lightweight qualitative analysis. Skips financial pipeline entirely. Uses Screener about text + web search to build a business profile. Options * --symbol -s TEXT Stock symbol [required] --skip-fetch Skip data refresh, use cached DB data --model TEXT Claude model override --help Show this message and exit.',
    'research data --help': 'Usage: flowtrack research data [OPTIONS] TOOL_NAME Query any research data tool directly. Prints JSON output. Examples: flowtrack research data shareholding_changes -s INDIAMART flowtrack research data macro_snapshot flowtrack research data composite_score -s RELIANCE Arguments * tool_name TEXT Tool to query: company_info, company_profile, company_documents, quarterly_results, annual_financials, screener_ratios, valuation_snapshot, valuation_band, pe_history, shareholding, shareholding_changes, insider_transactions, bulk_block_deals, mf_holdings, delivery_trend, promoter_pledge, consensus_estimate, earnings_surprises, macro_snapshot, fii_dii_streak, fii_dii_flows, chart_data, peer_comparison, shareholder_detail, expense_breakdown, recent_filings, composite_score, dcf_valuation, dcf_history, technical_indicators, dupont_decomposition, key_metrics_history, financial_growth_rates, analyst_grades, price_targets, fair_value, upcoming_catalysts, sector_overview, sector_flows, sector_valuations [required] Options --symbol -s TEXT Stock symbol --raw Print raw JSON instead of pretty --help Show this message and exit.',
    'research fundamentals --help': 'Usage: flowtrack research fundamentals [OPTIONS] Generate a fundamentals HTML report for a stock. Fetches fresh data from Screener.in, yfinance, and NSE, then renders a Jinja2 template and opens the report in the browser. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.',
    'research run --help': "Usage: flowtrack research run [OPTIONS] AGENTS Run specialist research agents on a stock. Run one or more agents by name (comma-separated), then optionally synthesize and assemble using existing briefings for the rest. Examples: flowtrack research run business -s HDFCBANK # just business flowtrack research run business,risk -s HDFCBANK # re-run two agents flowtrack research run synthesis -s HDFCBANK # just re-synthesize from existing briefings flowtrack research run business,risk,synthesis -s HDFCBANK --assemble # re-run two + synthesize + assemble HTML Arguments * agents TEXT Agents to run: business,risk,synthesis (comma-separated) or 'all' [required] Options * --symbol -s TEXT Stock symbol (e.g. INDIAMART) [required] --skip-fetch Skip data refresh --verify Run verification after agents --model -m TEXT Override model for agent --assemble Assemble final report from all existing briefings after running --effort TEXT Override effort level: low|medium|high|max --help Show this message and exit.",
    'research thesis --help': 'Usage: flowtrack research thesis [OPTIONS] Generate comprehensive multi-agent equity research thesis. Runs 7 specialist agents in parallel (business, financials, ownership, valuation, risk, technical, sector), verifies their reports, synthesizes everything, then adds beginner-friendly annotations via the explainer agent. Use --no-agent to fall back to the data-only HTML fundamentals report. Use --skip-fetch to skip refreshing data from live sources. Use --skip-verify to skip the verification step. Use --technical to skip the explainer and output technical-only report. Options * --symbol -s TEXT Stock symbol [required] --no-agent Skip agent, use data-only report (fallback to fundamentals) --skip-fetch Skip data refresh --skip-verify Skip verification step --model -m TEXT Override model for all agents --verify-model TEXT Override model for verifiers --technical Skip explainer, output technical report only --effort TEXT Override effort level: low|medium|high|max --help Show this message and exit.',
    'research thesis-check --help': "Usage: flowtrack research thesis-check [OPTIONS] Quick condition check for a tracked stock's thesis. Reads the tracker file at ~/vault/stocks/{SYMBOL}/thesis-tracker.md, evaluates conditions against fresh data, and updates statuses. Options * --symbol -s TEXT Stock symbol [required] --help Show this message and exit.",
    'research thesis-status --help': 'Usage: flowtrack research thesis-status [OPTIONS] Summary of all tracked stocks with condition status. Options --help Show this message and exit.',
    'research verify --help': 'Usage: flowtrack research verify [OPTIONS] AGENT Verify an existing specialist report (checks data accuracy). Arguments * agent TEXT Agent to verify: business|financials|ownership|valuation|risk|technical [required] Options * --symbol -s TEXT Stock symbol [required] --model -m TEXT Override model for verifier --help Show this message and exit.',
    'scan --help': 'Usage: flowtrack scan [OPTIONS] COMMAND [ARGS]... Nifty 250 shareholding scanner — batch fetch and rank ownership deviations Options --help Show this message and exit. Commands refresh Fetch all Nifty 250 constituents from NSE and upsert into store. constituents Show index constituents from the local store. fetch Batch fetch shareholding for all scanner stocks. deviations Show biggest shareholding deviations across Nifty 250. pledges Show stocks with high promoter pledging across Nifty 250. status Show scanner coverage stats.',
    'scan constituents --help': "Usage: flowtrack scan constituents [OPTIONS] Show index constituents from the local store. Options --index -i TEXT Filter by index name (e.g. 'NIFTY 50') --help Show this message and exit.",
    'scan deviations --help': 'Usage: flowtrack scan deviations [OPTIONS] Show biggest shareholding deviations across Nifty 250. Options --category -c TEXT Filter by category: FII, DII, MF, Promoter, Public --limit -n INTEGER Number of results [default: 20] --handoff Show FII→MF handoff signals instead --min-change FLOAT Minimum absolute change % to include [default: 0.0] --help Show this message and exit.',
    'scan fetch --help': 'Usage: flowtrack scan fetch [OPTIONS] Batch fetch shareholding for all scanner stocks. Options --force Re-fetch all, ignoring existing data --quarters -q INTEGER Number of quarters to fetch [default: 2] --limit -l INTEGER Limit to N stocks (0=all) [default: 0] --help Show this message and exit.',
    'scan pledges --help': 'Usage: flowtrack scan pledges [OPTIONS] Show stocks with high promoter pledging across Nifty 250. Options --min FLOAT Minimum pledge % to show [default: 1.0] --limit -n INTEGER Number of results [default: 20] --help Show this message and exit.',
    'scan refresh --help': 'Usage: flowtrack scan refresh [OPTIONS] Fetch all Nifty 250 constituents from NSE and upsert into store. Options --help Show this message and exit.',
    'scan status --help': 'Usage: flowtrack scan status [OPTIONS] Show scanner coverage stats. Options --help Show this message and exit.',
    'screen --help': 'Usage: flowtrack screen [OPTIONS] COMMAND [ARGS]... Composite stock screener — multi-factor scoring across all data layers Options --help Show this message and exit. Commands top Show top-ranked stocks across all factors. rank Rank stocks with custom weights, industry filter, and score threshold. score Show full scorecard for a single stock.',
    'screen score --help': 'Usage: flowtrack screen score [OPTIONS] SYMBOL Show full scorecard for a single stock. Arguments * symbol TEXT Stock symbol [required] Options --help Show this message and exit.',
    'screen top --help': 'Usage: flowtrack screen top [OPTIONS] Show top-ranked stocks across all factors. Options --limit -n INTEGER Number of stocks to show [default: 30] --factor TEXT Rank by single factor: ownership, insider, valuation, earnings, quality, delivery, estimates, risk --watchlist Score watchlist stocks only --help Show this message and exit.',
    'sector --help': "Usage: flowtrack sector [OPTIONS] COMMAND [ARGS]... Sector aggregation — ownership shifts and rotation by industry Options --help Show this message and exit. Commands overview Show sector-level ownership shifts across all industries. detail Drill into a specific sector's stock-level ownership data. list List all available industry/sector names.",
    'sector detail --help': "Usage: flowtrack sector detail [OPTIONS] INDUSTRY Drill into a specific sector's stock-level ownership data. Arguments * industry TEXT Industry name (use 'sector list' to see options) [required] Options --help Show this message and exit.",
    'sector list --help': 'Usage: flowtrack sector list [OPTIONS] List all available industry/sector names. Options --help Show this message and exit.',
    'sector overview --help': 'Usage: flowtrack sector overview [OPTIONS] Show sector-level ownership shifts across all industries. Options --help Show this message and exit.',
    'streak --help': 'Usage: flowtrack streak [OPTIONS] Show current FII/DII buying/selling streaks. Options --help Show this message and exit.',
    'summary --help': "Usage: flowtrack summary [OPTIONS] Show most recent day's FII/DII flows. Options --help Show this message and exit.",
  })
# ---
